# ──────────────────────────────────────────────
# Option A: DeepSeek (recommended — cheapest)
# Get your key at: https://platform.deepseek.com
# Pricing: ~¥1/1M input tokens, ~¥2/1M output tokens
# ──────────────────────────────────────────────
LLM_API_KEY=sk-your-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ──────────────────────────────────────────────
# Option B: OpenAI (also works, just more expensive)
# Uncomment and fill in if you prefer OpenAI
# ──────────────────────────────────────────────
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini
